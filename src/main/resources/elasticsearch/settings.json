{
  "analysis": {
    "analyzer": {
      "edge_ngram_analyzer": {
        "type": "custom",
        "tokenizer": "edge_ngram_tokenizer",
        "filter": [ "lowercase" ]
      },
      "product_index_analyzer": {
        "type": "custom",
        "char_filter": ["icu_normalizer"],  
        "tokenizer": "nori_index_tokenizer",
        "filter": [
          "nori_readingform",
          "nori_number",
          "nori_pos_filter",
          "icu_normalizer",
          "lowercase"
        ]
      },
      "product_search_analyzer": {
        "type": "custom",
        "char_filter": ["icu_normalizer"],  
        "tokenizer": "nori_search_tokenizer",
        "filter": [
          "nori_readingform",
          "nori_number",
          "nori_pos_filter",
          "icu_normalizer",
          "lowercase",
          "pro_synonym_graph_filter"
        ]
      },
      "chosung_index_analyzer":{
        "type":"custom",
        "filter":[
            "lowercase",
            "ngram_filter"
        ],
        "char_filter":[
            "nfd_normalizer",
            "make_chosung_filter"
        ],
        "tokenizer":"icu_tokenizer"
      },
      "chosung_search_analyzer" : {
        "type":"custom",
        "filter":[
            "lowercase",
            "ngram_filter"
        ],
        "char_filter":[
            "chosung_only_filter",
            "nfd_normalizer"
        ],
        "tokenizer":"icu_tokenizer"
      }
    },
    "tokenizer": {
      "edge_ngram_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 2,
        "max_gram": 10,
        "token_chars": [ "letter", "digit" ]
      },
      "nori_index_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "mixed",
        "discard_punctuation": true,
        "user_dictionary": "/usr/share/elasticsearch/config/analysis/userdict.txt"
      },
      "nori_search_tokenizer": {
        "type": "nori_tokenizer",
        "decompound_mode": "none",
        "user_dictionary": "/usr/share/elasticsearch/config/analysis/userdict.txt"
      }
    },
    "char_filter":{
      "nfd_normalizer":{
        "name":"nfkc",
        "mode":"decompose",
        "type":"icu_normalizer"
      },
      "make_chosung_filter":{
        "type":"pattern_replace",
        "pattern":"[^\u1100-\u1112^0-9a-zA-Z가-힣ㄱ-ㅎ ㅏ-ㅑ]",
        "replacement":""
      },
      "chosung_only_filter":{
        "type":"pattern_replace",
        "pattern":"[^ㄱ-ㅎa-zA-Z0-9]",
        "replacement":""
      }
    },
    "filter":{
      "pro_synonym_graph_filter": {
        "type": "synonym_graph", 
        "synonyms_path": "/usr/share/elasticsearch/config/analysis/synonyms.txt",
        "expand":true,
        "updateable": true
      },
      "nori_pos_filter" : {
        "type": "nori_part_of_speech",
        "stoptags": [
          "E", "IC", "J", "MAG", "MAJ", "MM", "SP", "SSC", "SSO", "SC", "SE", "XPN", "XSA", "XSN", "XSV", "UNA", "NA", "VSV"
        ]
      },
      "ngram_filter":{
        "type":"ngram",
        "min_gram":1,
        "max_gram":2
      }
    }
  }
}